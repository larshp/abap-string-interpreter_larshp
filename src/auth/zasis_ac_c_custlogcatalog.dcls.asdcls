@EndUserText.label: 'ASIS - Access Control for Custom Logic Catalog (C)'
@MappingRole: true
define role ZASIS_AC_C_CUSTLOGCATALOG {
    grant
        select
            on
                ZASIS_C_CUSTLOGCATALOG
                    where
                        inheriting conditions from entity ZASIS_I_CUSTLOGCATALOG;

}
