### GET RuleSet Definition - MySample
GET {{baseUrl}}/ruleSet/MySample?sap-client={{client}}
Authorization: Basic {{auth_b64}}
Accept: application/json

### GET RuleSet Definition - Unknown RuleSet (expect error)
GET {{baseUrl}}/ruleSet/UNKNOWN_RULESET?sap-client={{client}}
Authorization: Basic {{auth_b64}}
Accept: application/json

### Execute RuleSet - MySample (barcode with MaterialNo and DeliveryNote)
POST {{baseUrl}}/ruleSetExecution/MySample?sap-client={{client}}
Authorization: Basic {{auth_b64}}
Content-Type: application/json
Accept: application/json

{
  "string_to_be_interpreted": "<Start><A7X>MyMaterialNumber<B52H>MyDeliveryNote<End>"
}

### Execute RuleSet - MySample (no match in string)
POST {{baseUrl}}/ruleSetExecution/MySample?sap-client={{client}}
Authorization: Basic {{auth_b64}}
Content-Type: application/json
Accept: application/json

{
  "string_to_be_interpreted": "<Start><NO_KNOWN_TAG>SomeValue<End>"
}

### Execute RuleSet - Unknown RuleSet (expect error)
POST {{baseUrl}}/ruleSetExecution/UNKNOWN_RULESET?sap-client={{client}}
Authorization: Basic {{auth_b64}}
Content-Type: application/json
Accept: application/json

{
  "string_to_be_interpreted": "<Start><A7X>MyMaterialNumber<End>"
}

### GET RuleSet - without auth (expect 401/403)
GET {{baseUrl}}/ruleSet/MySample?sap-client={{client}}
Accept: application/json

### Execute RuleSet - MySample with context (expect 200)
POST {{baseUrl}}/ruleSetExecution/MySample?sap-client={{client}}
Authorization: Basic {{auth_b64}}
Content-Type: application/json
Accept: application/json

{
  "string_to_be_interpreted": "<Start><A7X>MyMaterialNumber<B52H>MyDeliveryNote<End>",
  "context": [
    { "ctx_key": "plant", "value": "1000" },
    { "ctx_key": "source", "value": "scanner_01" }
  ]
}

### Execute RuleSet - MySample with empty context array (expect 200)
POST {{baseUrl}}/ruleSetExecution/MySample?sap-client={{client}}
Authorization: Basic {{auth_b64}}
Content-Type: application/json
Accept: application/json

{
  "string_to_be_interpreted": "<Start><A7X>MyMaterialNumber<End>",
  "context": []
}

### Execute RuleSet - empty string_to_be_interpreted (expect 400)
POST {{baseUrl}}/ruleSetExecution/MySample?sap-client={{client}}
Authorization: Basic {{auth_b64}}
Content-Type: application/json
Accept: application/json

{
  "string_to_be_interpreted": ""
}

### Execute RuleSet - missing string_to_be_interpreted (expect 400)
POST {{baseUrl}}/ruleSetExecution/MySample?sap-client={{client}}
Authorization: Basic {{auth_b64}}
Content-Type: application/json
Accept: application/json

{}

### Execute RuleSet - wrong Content-Type (expect 400)
POST {{baseUrl}}/ruleSetExecution/MySample?sap-client={{client}}
Authorization: Basic {{auth_b64}}
Content-Type: text/plain
Accept: application/json

some plain text

### Unsupported HTTP method PUT (expect 405)
PUT {{baseUrl}}/ruleSetExecution/MySample?sap-client={{client}}
Authorization: Basic {{auth_b64}}
Content-Type: application/json
Accept: application/json

{
  "string_to_be_interpreted": "test"
}
