{
  "name": "abap-string-interpreter",
  "private": true,
  "version": "0.4.0",
  "description": "ZASIS - ABAP String Interpreter",
  "scripts": {
    "unit": "node -e \"fs=require('fs');fs.rmSync('output',{recursive:true,force:true})\" && abap_transpile && echo RUNNING && node output/index.mjs",
    "lint": "abaplint",
    "test": "npm run lint && npm run unit",
    "icf-test": "node --test __test/integration/icf.test.mjs",
    "icf-server": "node __test/integration/serve.mjs",
    "sap-test": "node --test __test/integration/sap.test.mjs",
    "sap-auth-test": "node --test __test/integration/sap-auth.test.mjs"
  },
  "author": "",
  "license": "Unlicense",
  "devDependencies": {
    "@abaplint/cli": "^2.119.23",
    "@abaplint/database-sqlite": "^2.11.78",
    "@abaplint/runtime": "^2.13.26",
    "@abaplint/transpiler-cli": "^2.13.26",
    "express": "^4.22.2",
    "jest": "^30.4.2"
  }
}
